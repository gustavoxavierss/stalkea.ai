{
  "version": 2,
  "builds": [
    {
      "src": "api/instagram.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/instagram(.*)",
      "dest": "/api/instagram.js"
    },
    {
      "src": "/api.php(.*)",
      "dest": "/api/instagram.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
